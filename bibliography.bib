	langid = {english},
	file = {PDF:C\:\\Users\\HP\\Zotero\\storage\\NTVQDUCE\\Li et al. - 2020 - BiLO-CPDP bi-level programming for automated model discovery in cross-project defect prediction.pdf:application/pdf},
